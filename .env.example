# Copy to .env and fill in — NEVER commit .env (it is gitignored).

# Your Nebius API key (used to call the deployed Endpoint and the agent's LLM).
NEBIUS_API_KEY=

# The model the Serverless Endpoint serves (the model-under-test).
ENDPOINT_MODEL=Qwen/Qwen2.5-1.5B-Instruct

# The agent's "brain" — a cheap chat model on Nebius Token Factory used to
# reason over benchmark results and propose the next serving config.
AGENT_LLM_BASE_URL=https://api.tokenfactory.nebius.com/v1
AGENT_LLM_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
