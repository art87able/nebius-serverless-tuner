# Copy to .env and fill in — NEVER commit .env (it is gitignored).

# API key used to call the deployed Endpoint (and the agent's LLM, if external).
NEBIUS_API_KEY=

# The model the Serverless Endpoint serves (the model-under-test).
ENDPOINT_MODEL=Qwen/Qwen2.5-1.5B-Instruct

# The agent's "brain".
# Self-contained mode (recommended): the literal value `endpoint` routes the
# agent's calls to the endpoint the tuner itself deploys — no external LLM API.
AGENT_LLM_BASE_URL=endpoint
# Alternative: any OpenAI-compatible base URL + model, e.g.:
# AGENT_LLM_BASE_URL=https://api.tokenfactory.nebius.com/v1
# AGENT_LLM_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
